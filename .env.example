# ===== LLM Configuration =====
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096

# ===== Vector DB (ChromaDB) =====
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_GENERAL=general_measures
CHROMA_COLLECTION_SCENARIOS=scenario_measures
CHROMA_COLLECTION_HISTORY=history_measures

# ===== Embedding Model =====
EMBEDDING_MODEL=text-embedding-ada-002
# Or use local model: EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===== RAG Relevance Threshold =====
# Range: 0.0 ~ 1.0. Results below this score are filtered out before injecting into LLM prompt.
# 0.65 = recommended starting point (balanced recall vs noise).
# Raise to 0.70~0.75 once the knowledge base has sufficient content.
# Lower to 0.50~0.60 in early stage with sparse knowledge base.
RAG_SCORE_THRESHOLD=0.65

# ===== API Server =====
API_HOST=0.0.0.0
API_PORT=8080
API_DEBUG=false
# Bearer Token for API authentication (REQUIRED for production)
# All endpoints except /health require: Authorization: Bearer <token>
# Generate a secure token: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKEN=
# Allowed CORS origins (comma-separated). Use '*' only for development.
API_CORS_ORIGINS=*

# ===== Short-term Memory =====
MEMORY_MAX_TOKENS=4000
MEMORY_WINDOW_SIZE=20

# ===== Human Confirmation =====
# Timeout in seconds waiting for human approval
HUMAN_CONFIRM_TIMEOUT=300
# Webhook URL to send confirmation requests (optional)
HUMAN_CONFIRM_WEBHOOK_URL=

# ===== Notification =====
# DingTalk / Slack / Email etc.
NOTIFY_DINGTALK_WEBHOOK=
NOTIFY_SLACK_WEBHOOK=
NOTIFY_EMAIL_SMTP_HOST=
NOTIFY_EMAIL_SMTP_PORT=465
NOTIFY_EMAIL_USER=
NOTIFY_EMAIL_PASSWORD=
NOTIFY_EMAIL_RECIPIENTS=ops@example.com

# ===== Redis (monitoring target, not agent's own cache) =====
MONITOR_REDIS_HOST=127.0.0.1
MONITOR_REDIS_PORT=6379
MONITOR_REDIS_PASSWORD=
MONITOR_REDIS_DB=0

# ===== Database (monitoring target) =====
MONITOR_DB_HOST=127.0.0.1
MONITOR_DB_PORT=3306
MONITOR_DB_USER=readonly_user
MONITOR_DB_PASSWORD=
MONITOR_DB_NAME=production

# ===== RabbitMQ (monitoring target) =====
MONITOR_MQ_HOST=127.0.0.1
MONITOR_MQ_PORT=5672
MONITOR_MQ_USER=guest
MONITOR_MQ_PASSWORD=guest
MONITOR_MQ_MANAGEMENT_PORT=15672

# ===== SSH (for remote server operations) =====
SSH_DEFAULT_USER=ops
SSH_DEFAULT_KEY_PATH=~/.ssh/id_rsa
SSH_DEFAULT_PORT=22

# ===== Tool Safety =====
# Comma-separated list of hosts that are forbidden to restart
RESTART_BLACKLIST_HOSTS=
# Max retries for tool calls
TOOL_MAX_RETRIES=3
TOOL_RETRY_WAIT_SECONDS=2

# ===== MCP: Prometheus =====
# Prometheus HTTP API URL (e.g., http://prometheus:9090)
# Leave empty to disable Prometheus tools
MCP_PROMETHEUS_URL=
MCP_PROMETHEUS_TIMEOUT=30

# ===== MCP: Elasticsearch =====
# Elasticsearch HTTP URL (e.g., http://elasticsearch:9200)
# Leave empty to disable Elasticsearch tools
MCP_ELASTICSEARCH_URL=
MCP_ELASTICSEARCH_USER=
MCP_ELASTICSEARCH_PASSWORD=
MCP_ELASTICSEARCH_TIMEOUT=30

# ===== MCP: Kubernetes =====
# Set to true and provide API URL / Token to enable K8s tools
MCP_KUBERNETES_ENABLED=false
MCP_KUBERNETES_API_URL=https://kubernetes.default.svc
MCP_KUBERNETES_TOKEN=
MCP_KUBERNETES_TIMEOUT=30

# ===== MCP: DingTalk =====
# DingTalk custom robot Webhook URL
MCP_DINGTALK_WEBHOOK=
# DingTalk robot signing secret (optional, for signed mode)
MCP_DINGTALK_SECRET=

# ===== MCP: PostgreSQL =====
# PostgreSQL connection DSN (e.g., postgresql://readonly:pass@host:5432/dbname)
# Leave empty to disable PostgreSQL tools
MCP_POSTGRES_DSN=

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=./logs/weops_agent.log
AUDIT_LOG_FILE=./logs/audit.log
